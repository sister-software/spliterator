{
	"name": "spliterator",
	"version": "2.2.1",
	"description": "Line-delimited iterator library for CSV, NDJSON, and other delimited formats.",
	"keywords": [
		"csv",
		"ndjson",
		"jsonl",
		"iterator",
		"line-delimited",
		"delimited"
	],
	"homepage": "https://github.com/sister-software/spliterator",
	"bugs": {
		"url": "https://github.com/sister-software/spliterator/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sister-software/spliterator.git"
	},
	"license": "AGPL-3.0-only",
	"contributors": [
		{
			"name": "Teffen Ellis",
			"email": "teffen@sister.software"
		}
	],
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": "./out/index.js",
		"./node/fs": "./out/node/fs/index.js",
		"./test/utils": "./out/test/utils.js"
	},
	"bin": "./out/node/cli/index.js",
	"files": [
		"out/index.d.ts",
		"out/index.d.ts.map",
		"out/index.js.map",
		"out/index.js",
		"out/lib/**/*",
		"out/node/**/*",
		"out/cli/**/*"
	],
	"scripts": {
		"check-types": "tsc --build .",
		"clean": "tsc -b --clean",
		"compile": "NODE_OPTIONS=\"--max-old-space-size=3000\" tsc -b",
		"demo": "node out/examples/simple-iteration.js",
		"lint": "run-s lint:prettier:check lint:eslint:check",
		"lint:eslint:check": "eslint .",
		"lint:eslint:fix": "eslint --fix .",
		"lint:fix": "run-s lint:prettier:fix lint:eslint:fix",
		"lint:prettier": "eslint .",
		"lint:prettier:check": "prettier --cache --check -u .",
		"lint:prettier:fix": "prettier --cache --write -u .",
		"release": "release-it",
		"test": "yarn compile && vitest"
	},
	"prettier": "@sister.software/prettier-config",
	"dependencies": {
		"yargs": "^18.0.0"
	},
	"devDependencies": {
		"@sister.software/eslint-config": "^8.0.1",
		"@sister.software/prettier-config": "^8.0.1",
		"@sister.software/tsconfig": "^8.0.1",
		"@types/node": "^25.9.0",
		"@types/yargs": "^17.0.35",
		"change-case": "^5.4.4",
		"colorette": "^2.0.20",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"npm-run-all": "^4.1.5",
		"path-ts": "^1.0.5",
		"prettier": "^3.8.3",
		"prettier-plugin-jsdoc": "^1.8.0",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-packagejson": "^3.0.2",
		"release-it": "^17.10.0",
		"type-fest": "^5.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.4",
		"vitest": "^4.1.6"
	},
	"peerDependencies": {
		"change-case": "^5.4.4",
		"type-fest": "^5.6.0"
	},
	"peerDependenciesMeta": {
		"change-case": {
			"optional": true
		},
		"type-fest": {
			"optional": true
		}
	},
	"packageManager": "yarn@4.5.1",
	"engines": {
		"node": ">= 24.0.0"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org"
	},
	"release-it": {
		"npm": {
			"publish": true
		}
	}
}
